# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose uses the POSTGRES_* vars to create the DB at first boot.
# DATABASE_URL is overridden by docker-compose.yml to point at the 'db' service.
DATABASE_URL=postgresql://user:pass@localhost:5432/ev_policy_intel
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=ev_policy_intel

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # required for AI chat (claude-sonnet-4-6)
OPENAI_API_KEY=              # required for embeddings (text-embedding-3-small)

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=changeme         # set a strong secret in production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Local dev: http://localhost:5173
# Staging:   https://your-domain.com
CORS_ORIGINS=http://localhost:5173

# ── Notifications (ingestion monitor) ────────────────────────────────────────
# Leave blank to disable.
NOTIFY_EMAIL=                # SendGrid recipient address
NOTIFY_WEBHOOK=              # HTTP POST URL (Slack incoming webhook, etc.)
SENDGRID_API_KEY=            # Required only if NOTIFY_EMAIL is set

# ── Staging-only ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost  # Used by docker-compose.staging.yml for CORS_ORIGINS
